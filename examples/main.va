// ═══════════════════════════════════════════════════════════════════════════
// 14. 杂项 — 链式调用 / 索引赋值 / 嵌套字典
// ═══════════════════════════════════════════════════════════════════════════
print("\n── 14. 杂项 ──")

T(" x ".trim().upper() == "X")

let ia = [1,2,3]
ia[1] = 99
T(ia[1] == 99)

// [WISH] 属性简写 (shorthand property)
// 期望: let name = "Vora"; let obj = {name}  → {name: "Vora"}
// 现状优点: 显式 {name: name} 无歧义
// 现状缺点: 变量名=属性名时重复写两遍
// 期望优点: 紧凑; JS/TS 标准
// 期望缺点: 语法糖; 初学者可能困惑 {name} 是变量还是字符串键

let nd = {user: {name: "V", tags: ["x"]}}
T(nd.user.name == "V")
T(nd.user.tags[0] == "x")


// ═══════════════════════════════════════════════════════════════════════════
print("\n══════════════════════════════════")
print("  " + toString(ok) + " passed, " + toString(ng) + " failed")
