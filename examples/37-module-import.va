// examples/37-module-import.va — Module import demonstration
import "math"

print("PI = " + toString(math.PI))
print("sin(pi/2) = " + toString(math.sin(math.PI / 2)))
print("sqrt(2) = " + toString(math.sqrt(2)))

let numbers = [3, 7, 2, 9, 1, 5]
print("min = " + toString(math.min(numbers)))
print("max = " + toString(math.max(numbers)))

let ri = math.random.int(1, 100)
print("Random int 1-100: " + toString(ri))
let rf = math.random.float(0, 1, 3)
print("Random float 0-1: " + toString(rf))
