// 类型标注与类型转换 int() float()
// 交互式 input() 演示
// 自动化测试： printf '42\n3.14\n100\ntest\n' | vora examples/17-type-annotations.va
print("=== type annotations & input ===")
let line1:int = int(input("int: "))
let line2:float = float(input("float: "))
let line3 = int(input("int: "))
let line4:int = input("any: ")
print(line1, line2, line3, line4)

// 类型转换（无交互）
print("=== type conversion ===")
print(int(3.14))
print(float(42))
print(int(true))
print(float(false))
