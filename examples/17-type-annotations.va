// 类型标注与类型转换 int() float()
print("=== input ===")
let line1:int = int(input("Please enter a int value: "))
let line2:float = float(input("Please enter a float value: "))
let line3 = int(input("Please enter a int value: "))
let line4:int = input("Please enter a int value: ")
print("you typed: ", line1, line2, line3, line4)
