Obj Person(name, age) {
    this.name = name
    this.age = age
    func greet() {
        print("I'm " + this.name + ", age " + this.age)
    }
    func birthday() {
        this.age = this.age + 1
    }
}
let alice = Person("Alice", 25)
alice.greet()
print(alice.name)
print(alice.age)
alice.age = 26
print(alice.age)
alice.birthday()
print(alice.age)
alice.age++
print(alice.age)
