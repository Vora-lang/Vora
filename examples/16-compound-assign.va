// 复合赋值 += -= *= /= %=
let x = 10
x += 5
print(x)   // 15

x -= 3
print(x)   // 12

x *= 2
print(x)   // 24

x /= 4
print(x)   // 6

x %= 4
print(x)   // 2

// 字符串拼接
let s = "Hello"
s += " World"
print(s)  // "Hello World"

// 数组追加
let arr = [1, 2]
arr += [3, 4]
print(arr)  // [1, 2, 3, 4]

// 与循环配合
let sum = 0
let i = 1
while (i <= 5) {
    sum += i
    i += 1
}
print(sum)  // 15
