// Windows resource file for Vora executable icon
// Generated by CMake from vora.rc.in — version numbers come from CMakeLists.txt

// Application icon — ID 1 is the default application icon
IDI_ICON1               ICON    "@CMAKE_SOURCE_DIR@/res/vora.ico"

// Version info
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName",      "Vora-lang"
            VALUE "FileDescription",  "Vora is a dynamically typed scripting language. It features JavaScript-like syntax, Lua-level simplicity, and Wren-style object orientation."
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "Vora"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "Vora.exe"
            VALUE "ProductName",      "Vora"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1252
    END
END
