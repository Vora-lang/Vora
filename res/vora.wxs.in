<?xml version="1.0" encoding="UTF-8"?>

<!--
  Vora MSI installer — WiX v3 format.
  Generated by CMake from vora.wxs.in.
  Version and paths come from CMakeLists.txt.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
      Id="*"
      Name="Vora"
      Language="1033"
      Version="@PROJECT_VERSION@"
      Manufacturer="Vora-lang"
      UpgradeCode="A9A1F393-D8B7-4CD2-9DC6-E2A8DE7EB7A2">

    <Package
        InstallerVersion="301"
        Compressed="yes"
        InstallScope="perMachine"
        Platform="x64" />

    <!-- Upgrade: remove old version early so original MSI source is not needed.
         Downgrade blocked: newer → older is refused. -->
    <MajorUpgrade
        Schedule="afterInstallInitialize"
        DowngradeErrorMessage="A newer version of Vora is already installed." />

    <!-- License agreement (MIT) — displayed by WixUI_InstallDir -->
    <WixVariable Id="WixUILicenseRtf" Value="@CMAKE_SOURCE_DIR@/res/LICENSE.rtf" />

    <MediaTemplate EmbedCab="yes" />

    <!-- ARP (Add/Remove Programs) -->
    <Icon Id="vora.ico" SourceFile="@CMAKE_SOURCE_DIR@/res/vora.ico" />
    <Property Id="ARPPRODUCTICON" Value="vora.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Vora-lang/Vora" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Vora-lang/Vora" />
    <!-- WixUI — install directory chooser (ARPNOREPAIR/ARPNOMODIFY
         are already defined by WixUI_InstallDir) -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Vora">

          <!-- bin/ — executables -->
          <Directory Id="BinDir" Name="bin">
            <Component Id="MainExe" Guid="B8E2F914-3D57-4A16-9C1F-CDAE62788B3E">
              <File Id="VoraExe" Source="@CMAKE_BINARY_DIR@/Release/Vora.exe" KeyPath="yes" />
            </Component>
            <Component Id="LspExe" Guid="E5A1B723-C906-4D93-AF0E-37F6A2B85A72">
              <File Id="VoraLspExe" Source="@CMAKE_BINARY_DIR@/Release/vora-lsp.exe" KeyPath="yes" />
            </Component>
            <Component Id="Launcher" Guid="D4E8A916-F705-4B83-AE1D-29C6C4B83D70">
              <File Id="VoraCmd" Source="@CMAKE_SOURCE_DIR@/res/vora.cmd" KeyPath="yes" />
            </Component>

            <!-- PATH env — points to bin\ for "vora" command -->
            <Component Id="PathEnv" Guid="C7D3A815-E694-4B82-9EF2-18D5B3A72C6F">
              <Environment Id="PathEntry" Name="PATH" Value="[BinDir]" Action="set" Part="last" System="yes" Permanent="no" />
              <RegistryKey Root="HKLM" Key="Software\Vora-lang\Vora">
                <RegistryValue Name="InstallDir" Value="[INSTALLFOLDER]" Type="string" KeyPath="yes" />
                <RegistryValue Name="Version" Value="@PROJECT_VERSION@" Type="string" />
              </RegistryKey>
            </Component>
          </Directory>

          <!-- std/ — standard library -->
          <Directory Id="StdDir" Name="std">
            <Component Id="StdMath" Guid="F1A2C834-E705-4C94-BF1F-48D6C3B83D71">
              <File Id="StdMathVa" Source="@CMAKE_SOURCE_DIR@/std/math.va" KeyPath="yes" />
            </Component>
            <Component Id="StdJson" Guid="A2B3D945-F816-4DA5-CF2F-59E7D4C94E82">
              <File Id="StdJsonVa" Source="@CMAKE_SOURCE_DIR@/std/json.va" KeyPath="yes" />
            </Component>
          </Directory>

        </Directory>
      </Directory>
    </Directory>

    <Feature Id="Main" Title="Vora" Level="1" Display="expand"
             Description="Vora programming language — interpreter, LSP server, and standard library"
             ConfigurableDirectory="INSTALLFOLDER">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="LspExe" />
      <ComponentRef Id="Launcher" />
      <ComponentRef Id="PathEnv" />
      <ComponentRef Id="StdMath" />
      <ComponentRef Id="StdJson" />
    </Feature>

  </Product>
</Wix>
