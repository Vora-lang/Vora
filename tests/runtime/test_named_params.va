// runtime/test_named_params.va — Named parameter tests
// Run: vora tests/runtime/test_named_params.va

print("=== Runtime: Named Parameter Tests ===")

// Basic named parameters
func greet(name, greeting = "Hello") {
    return greeting + ", " + name
}
assert(greet(name="World") == "Hello, World", "named param with default")
assert(greet(greeting="Hi", name="Vora") == "Hi, Vora", "reorder named params")

// Mixed positional + named
func sum(a, b = 2, c = 3) {
    return a + b + c
}
assert(sum(1, c=10) == 13, "positional + named")
assert(sum(1, b=10, c=100) == 111, "all params specified")

// All named, skip defaults
func allDefaults(a = 1, b = 2, c = 3) {
    return a + b + c
}
assert(allDefaults(b=20) == 24, "named skips first default")
assert(allDefaults(c=30, a=10) == 42, "named in any order")

// Named arg for function with no defaults
func noDefault(a, b) {
    return a * 10 + b
}
assert(noDefault(a=3, b=4) == 34, "named for required params")
assert(noDefault(b=5, a=2) == 25, "named reordered for required params")

// Named params with rest parameter
func withRest(a, b = 2, ...rest) {
    let sum = a + b
    for item in rest {
        sum = sum + item
    }
    return sum
}
assert(withRest(a=1) == 3, "named + rest, no extra")
assert(withRest(b=5, a=10) == 15, "named + rest, no extra")

// Named params with closures (indirect calls)
func apply(fn) {
    return fn(a=5, b=6)
}
func testFn(a, b) { return a + b }
assert(apply(testFn) == 11, "named args through indirect call")

print("Runtime named parameter tests: PASS")
