// runtime/test_functions.va — Function tests
// Run: vora tests/runtime/test_functions.va

print("=== Runtime: Function Tests ===")

// Basic function
func add(a, b) {
    return a + b
}
assert(add(1, 2) == 3, "basic function")
assert(add(10, -5) == 5, "negative arg")

// No return (returns null)
func noRet() {}
assert(noRet() == null, "no return yields null")

// Closure
func makeAdder(x) {
    func adder(y) {
        return x + y
    }
    return adder
}
let add5 = makeAdder(5)
assert(add5(3) == 8, "closure")

// Recursion
func factorial(n) {
    if (n <= 1) { return 1 }
    return n * factorial(n - 1)
}
assert(factorial(5) == 120, "recursion")

// First-class functions
func apply(f, x) {
    return f(x)
}
func double(x) { return x * 2 }
assert(apply(double, 7) == 14, "higher-order function")

// Nested closure
func outer(a) {
    func inner(b) {
        return a + b
    }
    return inner
}
let add10 = outer(10)
assert(add10(5) == 15, "nested closure")

// Multiple closures each capture independent snapshots
func makeCounters() {
    let count = 0
    func inc() {
        count += 1
        return count
    }
    func dec() {
        count -= 1
        return count
    }
    return [inc, dec]
}
let counters = makeCounters()
let incFn = counters[0]
let decFn = counters[1]
// Each closure has its own snapshot of count, starting from 0
assert(incFn() == 1, "snapshot inc1")
assert(incFn() == 2, "snapshot inc2")
// dec has its own independent copy of count
assert(decFn() == -1, "snapshot dec1")
assert(decFn() == -2, "snapshot dec2")

print("Runtime function tests: PASS")
