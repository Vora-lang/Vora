// Problem #25: House Robber (Medium)
// Rob houses along a street; cannot rob adjacent houses.
// DP: dp[i] = max(dp[i-1], dp[i-2] + nums[i]).
// Space-optimized: track prev2 (dp[i-2]) and prev1 (dp[i-1]).

func max(a, b) {
    if (a > b) {
        return a;
    }
    return b;
}

func rob(nums) {
    if (nums.length == 0) {
        return 0;
    }
    if (nums.length == 1) {
        return nums[0];
    }

    let prev2 = nums[0];           // dp[0]
    let prev1 = max(nums[0], nums[1]); // dp[1]

    for i in range(2, nums.length) {
        let cur = max(prev1, prev2 + nums[i]);
        prev2 = prev1;
        prev1 = cur;
    }

    return prev1;
}

// Test cases
assert(rob([]) == 0);
assert(rob([1]) == 1);
assert(rob([1, 2, 3, 1]) == 4);        // Rob house 1 and 3: 1+3=4
assert(rob([2, 7, 9, 3, 1]) == 12);    // Rob house 1,3,5: 2+9+1=12
assert(rob([2, 1, 1, 2]) == 4);        // Rob house 1 and 4: 2+2=4
assert(rob([5, 1, 2, 6]) == 11);       // Rob house 1 and 4: 5+6=11
assert(rob([10, 0, 0, 10]) == 20);     // Rob house 1 and 4: 10+10=20
assert(rob([4, 1, 2, 7, 5, 3, 1]) == 14); // 4+7+3=14 or 4+7+1? Actually 4+7+3=14

print("PASS: 25-house-robber");
