// Problem #29: Longest Increasing Subsequence (Medium)
// Length of the longest strictly increasing subsequence (LIS).
// DP: dp[i] = max(dp[j] + 1) for all j < i where nums[j] < nums[i].

func max(a, b) {
    if (a > b) {
        return a;
    }
    return b;
}

func lengthOfLIS(nums) {
    let n = nums.length;
    if (n == 0) {
        return 0;
    }

    // dp[i] = length of LIS ending at index i, initially 1
    let dp = [];
    for i in range(n) {
        dp.add(1);
    }

    let best = 1;
    for i in range(n) {
        for j in range(i) {
            if (nums[j] < nums[i]) {
                dp[i] = max(dp[i], dp[j] + 1);
            }
        }
        best = max(best, dp[i]);
    }

    return best;
}

// Test cases
assert(lengthOfLIS([10, 9, 2, 5, 3, 7, 101, 18]) == 4); // [2,3,7,101] or [2,5,7,101]
assert(lengthOfLIS([0, 1, 0, 3, 2, 3]) == 4);           // [0,1,2,3]
assert(lengthOfLIS([7, 7, 7, 7, 7, 7, 7]) == 1);
assert(lengthOfLIS([1, 2, 3, 4, 5]) == 5);
assert(lengthOfLIS([5, 4, 3, 2, 1]) == 1);
assert(lengthOfLIS([]) == 0);
assert(lengthOfLIS([1]) == 1);
assert(lengthOfLIS([2, 2]) == 1);
assert(lengthOfLIS([1, 3, 6, 7, 9, 4, 10, 5, 6]) == 6); // [1,3,6,7,9,10]

print("PASS: 29-longest-increasing-subsequence");
