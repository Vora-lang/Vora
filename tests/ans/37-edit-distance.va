// Problem #37: Edit Distance (Hard)
// Minimum operations (insert/delete/replace) to convert word1 to word2.
// Levenshtein DP: dp[i][j] = min cost to convert word1[0..i-1] to word2[0..j-1].
// Since Vora does not support arr[idx] = val, we rebuild each row with .add().

func min(a, b) {
    if (a < b) {
        return a;
    }
    return b;
}

func minDistance(word1, word2) {
    let m = word1.length;
    let n = word2.length;

    // Initialize dp row: dp[0..n]
    let dp = [];
    for j in range(n + 1) {
        dp.add(j);
    }

    for i in range(1, m + 1) {
        // Build new row
        let newDp = [];
        newDp.add(i);  // newDp[0] = i

        for j in range(1, n + 1) {
            if (word1[i - 1] == word2[j - 1]) {
                newDp.add(dp[j - 1]);
            } else {
                newDp.add(1 + min(min(dp[j], newDp[j - 1]), dp[j - 1]));
            }
        }

        dp = newDp;
    }

    return dp[n];
}

// Test cases
assert(minDistance("horse", "ros") == 3);           // horse -> rorse -> rose -> ros
assert(minDistance("intention", "execution") == 5);  // intention -> inention -> enention -> exention -> exection -> execution
assert(minDistance("", "a") == 1);
assert(minDistance("a", "") == 1);
assert(minDistance("", "") == 0);
assert(minDistance("abc", "abc") == 0);
assert(minDistance("kitten", "sitting") == 3);
assert(minDistance("saturday", "sunday") == 3);
assert(minDistance("abcdef", "azced") == 3);

print("PASS: 37-edit-distance");
