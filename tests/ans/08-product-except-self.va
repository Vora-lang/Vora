// Problem #8: Product Except Self (Medium)
// Array where each element = product of all others.
// Use prefix + suffix products (arrays).

func productExceptSelf(nums) {
    let n = nums.length;
    if n == 0 {
        return [];
    }

    let result = [];
    for i in range(n) {
        result.add(1);
    }

    // prefix products: result[i] = product of all elements to the left
    let prefix = 1;
    for i in range(n) {
        result[i] = prefix;
        prefix = prefix * nums[i];
    }

    // suffix products: result[i] *= product of all elements to the right
    let suffix = 1;
    let i = n - 1;
    while i >= 0 {
        result[i] = result[i] * suffix;
        suffix = suffix * nums[i];
        i = i - 1;
    }

    return result;
}

// Test cases
let r = productExceptSelf([1, 2, 3, 4]);
assert(r[0] == 24 and r[1] == 12 and r[2] == 8 and r[3] == 6);

r = productExceptSelf([-1, 1, 0, -3, 3]);
assert(r[0] == 0 and r[1] == 0 and r[2] == 9 and r[3] == 0 and r[4] == 0);

r = productExceptSelf([1, 2]);
assert(r[0] == 2 and r[1] == 1);

r = productExceptSelf([5, 5, 5]);
assert(r[0] == 25 and r[1] == 25 and r[2] == 25);

r = productExceptSelf([0, 1, 2]);
assert(r[0] == 2 and r[1] == 0 and r[2] == 0);

r = productExceptSelf([]);
assert(r.length == 0);

print("PASS: 08-product-except-self");
