// Problem #34: Minimum Path Sum (Medium)
// Grid, find path from top-left to bottom-right with minimum sum.
// Only move right or down. DP: dp[i][j] = grid[i][j] + min(dp[i-1][j], dp[i][j-1]).

func min(a, b) {
    if (a < b) {
        return a;
    }
    return b;
}

func minPathSum(grid) {
    let m = grid.length;
    if (m == 0) {
        return 0;
    }
    let n = grid[0].length;
    if (n == 0) {
        return 0;
    }

    // Use a 1D DP array (space optimized)
    let dp = [];
    // Initialize first row
    dp.add(grid[0][0]);
    for j in range(1, n) {
        dp.add(dp[j - 1] + grid[0][j]);
    }

    for i in range(1, m) {
        dp[0] = dp[0] + grid[i][0];
        for j in range(1, n) {
            dp[j] = grid[i][j] + min(dp[j], dp[j - 1]);
        }
    }

    return dp[n - 1];
}

// Test cases
assert(minPathSum([[1, 3, 1], [1, 5, 1], [4, 2, 1]]) == 7);
// Path: 1 -> 3 -> 1 -> 1 -> 1 = 7, but better: 1 -> 1 -> 2 -> 1? Let me compute.
// Actually: 1->1->4->2->1 = 9, 1->3->1->1->1 = 7, 1->1->5->1->1 = 9, 1->1->5->2->1 = 10
// Verified: min path is 1→3→1→1→1 = 7 ✓

assert(minPathSum([[1, 2, 3], [4, 5, 6]]) == 12);   // 1→2→3→6 = 12
assert(minPathSum([[1]]) == 1);
assert(minPathSum([[1, 2], [1, 1]]) == 3);           // 1→1→1 = 3
assert(minPathSum([[5]]) == 5);
assert(minPathSum([[]]) == 0);
assert(minPathSum([]) == 0);

// Larger test
let g = [[1, 4, 8, 6], [2, 3, 5, 7], [1, 2, 3, 1]];
// 1→4→8→6→7→1 is not right... Let's compute via DP
// dp row0: [1, 5, 13, 19]
// dp row1: [3, 6, 11, 18]  (3→1+3=4? No: dp[0]=3, then dp[1]=4+min(3,5)=7, dp[2]=5+min(7,11)=12, dp[3]=7+min(12,13)=19)
// Actually let me just trust the algorithm and check a known result
assert(minPathSum(g) == 1 + 2 + 1 + 2 + 3 + 1);
// Actually I'll verify: best path: 1→2→1→2→3→1 = 10
// Let me just assert the DP result
assert(minPathSum(g) <= 30); // Sanity check

