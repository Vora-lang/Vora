// #79 Word Search (Medium)
// DFS backtracking with visited tracking (top-level recursion for Vora compat).

func dfsWord(board, word, visited, rows, cols, i, j, idx) {
    if (idx == word.length) { return true }
    if (i < 0 or i >= rows or j < 0 or j >= cols) { return false }

    let searchKey = cols * i + j
    let vi = 0
    let foundVisited = false
    while (vi < visited.length) {
        if (visited[vi] == searchKey) { foundVisited = true }
        vi = vi + 1
    }
    if (foundVisited) { return false }
    if (board[i][j] != word[idx]) { return false }

    visited.add(searchKey)

    if (dfsWord(board, word, visited, rows, cols, i + 1, j, idx + 1)) { return true }
    if (dfsWord(board, word, visited, rows, cols, i - 1, j, idx + 1)) { return true }
    if (dfsWord(board, word, visited, rows, cols, i, j + 1, idx + 1)) { return true }
    if (dfsWord(board, word, visited, rows, cols, i, j - 1, idx + 1)) { return true }

    visited.pop()
    return false
}

func exist(board, word) {
    if (board.length == 0 or board[0].length == 0) { return false }
    if (word.length == 0) { return true }

    let rows = board.length
    let cols = board[0].length
    let visited = []

    let r = 0
    while (r < rows) {
        let c = 0
        while (c < cols) {
            if (dfsWord(board, word, visited, rows, cols, r, c, 0)) { return true }
            c = c + 1
        }
        r = r + 1
    }

    return false
}

// Tests
let b1 = [["A","B","C","E"],["S","F","C","S"],["A","D","E","E"]];
assert(exist(b1, "ABCCED") == true, "Test 1 failed");
assert(exist(b1, "SEE") == true, "Test 2 failed");
assert(exist(b1, "ABCB") == false, "Test 3 failed");
assert(exist([["A"]], "A") == true, "Test 4 failed");
assert(exist([["A"]], "B") == false, "Test 5 failed");
assert(exist([["a","b"],["c","d"]], "abcd") == false, "Test 6 failed");

print("59-word-search: PASS");
