// #79 Word Search (Medium)
// Check if word exists in board (adjacent cells). DFS backtracking with visited tracking.
// NOTE: v0.12 does not support arr[i][j] = val. We use a parallel visited array and rebuild on each change.

func exist(board, word) {
    if (board.length == 0 or board[0].length == 0) {
        return false;
    }
    if (word.length == 0) {
        return true;
    }

    let rows = board.length;
    let cols = board[0].length;

    // Instead of a 2D boolean array, use a flat array of strings marking visited cells.
    // Since there's no hash map, we use a single array of visited positions as "row,col" strings.
    let visited = [];

    func isVisited(r, c) {
        let key = type(r) + ":" + r + "," + c;  // dummy string key
        let searchKey = int(r) * cols + int(c);   // use a flat index approach
        let i = 0;
        while (i < visited.length) {
            if (visited[i] == searchKey) { return true; }
            i = i + 1;
        }
        return false;
    }

    func markVisited(r, c) {
        let searchKey = int(r) * cols + int(c);
        let idx = visited.indexOf(searchKey);
        if (idx == -1) {
            visited.add(searchKey);
        }
    }

    func unmarkVisited(r, c) {
        let searchKey = int(r) * cols + int(c);
        let idx = visited.indexOf(searchKey);
        if (idx != -1) {
            visited.remove(idx);
        }
    }

    func dfs(i, j, idx) {
        if (idx == word.length) {
            return true;
        }
        if (i < 0 or i >= rows or j < 0 or j >= cols) {
            return false;
        }
        if (isVisited(i, j)) {
            return false;
        }
        if (board[i][j] != word[idx]) {
            return false;
        }

        markVisited(i, j);

        if (dfs(i + 1, j, idx + 1)) { return true; }
        if (dfs(i - 1, j, idx + 1)) { return true; }
        if (dfs(i, j + 1, idx + 1)) { return true; }
        if (dfs(i, j - 1, idx + 1)) { return true; }

        unmarkVisited(i, j);
        return false;
    }

    let r = 0;
    while (r < rows) {
        let c = 0;
        while (c < cols) {
            if (dfs(r, c, 0)) {
                return true;
            }
            c = c + 1;
        }
        r = r + 1;
    }

    return false;
}

// Tests
let b1 = [["A","B","C","E"],["S","F","C","S"],["A","D","E","E"]];
assert(exist(b1, "ABCCED") == true, "Test 1 failed");
assert(exist(b1, "SEE") == true, "Test 2 failed");
assert(exist(b1, "ABCB") == false, "Test 3 failed");
assert(exist([["A"]], "A") == true, "Test 4 failed");
assert(exist([["A"]], "B") == false, "Test 5 failed");
assert(exist([["a","b"],["c","d"]], "abcd") == false, "Test 6 failed");

print("59-word-search: PASS");
