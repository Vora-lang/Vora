// #35 Search Insert Position (Easy)
// Sorted array, find insert position of target. Binary search.

func searchInsert(nums, target) {
    let left = 0;
    let right = nums.length - 1;

    while (left <= right) {
        let mid = left + int((right - left) / 2);
        if (nums[mid] == target) {
            return mid;
        }
        if (nums[mid] < target) {
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }

    return left;
}

// Tests
assert(searchInsert([1,3,5,6], 5) == 2, "Test 1 failed");
assert(searchInsert([1,3,5,6], 2) == 1, "Test 2 failed");
assert(searchInsert([1,3,5,6], 7) == 4, "Test 3 failed");
assert(searchInsert([1,3,5,6], 0) == 0, "Test 4 failed");
assert(searchInsert([1], 0) == 0, "Test 5 failed");
assert(searchInsert([], 5) == 0, "Test 6 failed");

print("53-search-insert-position: PASS");
