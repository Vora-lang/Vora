// #153 Find Minimum in Rotated Sorted Array (Medium)
// Find minimum in rotated sorted unique array. Binary search comparing mid with rightmost.

func findMin(nums) {
    let left = 0;
    let right = nums.length - 1;

    while (left < right) {
        let mid = left + int((right - left) / 2);
        if (nums[mid] > nums[right]) {
            left = mid + 1;
        } else {
            right = mid;
        }
    }

    return nums[left];
}

// Tests
assert(findMin([3,4,5,1,2]) == 1, "Test 1 failed");
assert(findMin([4,5,6,7,0,1,2]) == 0, "Test 2 failed");
assert(findMin([11,13,15,17]) == 11, "Test 3 failed");
assert(findMin([1]) == 1, "Test 4 failed");
assert(findMin([2,1]) == 1, "Test 5 failed");
assert(findMin([3,1,2]) == 1, "Test 6 failed");

print("57-find-min-rotated: PASS");
