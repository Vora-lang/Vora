// #42 Trapping Rain Water (Hard)
// Water trapped between bars. Two-pointer approach from ends tracking maxLeft/maxRight.

func trap(height) {
    if (height.length == 0) {
        return 0;
    }

    let left = 0;
    let right = height.length - 1;
    let maxLeft = 0;
    let maxRight = 0;
    let water = 0;

    while (left < right) {
        if (height[left] < height[right]) {
            if (height[left] >= maxLeft) {
                maxLeft = height[left];
            } else {
                water = water + (maxLeft - height[left]);
            }
            left = left + 1;
        } else {
            if (height[right] >= maxRight) {
                maxRight = height[right];
            } else {
                water = water + (maxRight - height[right]);
            }
            right = right - 1;
        }
    }

    return int(water);
}

// Tests
assert(trap([0,1,0,2,1,0,1,3,2,1,2,1]) == 6, "Test 1 failed");
assert(trap([4,2,0,3,2,5]) == 9, "Test 2 failed");
assert(trap([1,2,3]) == 0, "Test 3 failed");
assert(trap([3,2,1]) == 0, "Test 4 failed");
assert(trap([0,0,0]) == 0, "Test 5 failed");
assert(trap([5]) == 0, "Test 6 failed");

print("51-trapping-rain-water: PASS");
