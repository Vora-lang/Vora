// Problem #6: Merge Intervals (Medium)
// Given array of [start,end] intervals, merge overlapping ones.
// Sort by start then merge.

func bubbleSortIntervals(intervals) {
    let n = intervals.length;
    for i in range(n) {
        for j in range(0, n - i - 1) {
            if (intervals[j][0] > intervals[j + 1][0]) {
                let temp = intervals[j];
                intervals[j] = intervals[j + 1];
                intervals[j + 1] = temp;
            }
        }
    }
    return intervals;
}

func merge(intervals) {
    if (intervals.length <= 1) {
        return intervals;
    }

    let sorted = bubbleSortIntervals(intervals);
    let result = [sorted[0]];

    for i in range(1, sorted.length) {
        let last = result[result.length - 1];
        let current = sorted[i];

        if (current[0] <= last[1]) {
            // Overlap - merge
            if (current[1] > last[1]) {
                last[1] = current[1];
            }
        } else {
            result.add(current);
        }
    }
    return result;
}

// Test cases
let r = merge([[1, 3], [2, 6], [8, 10], [15, 18]]);
assert(r.length == 3);
assert(r[0][0] == 1 and r[0][1] == 6);
assert(r[1][0] == 8 and r[1][1] == 10);
assert(r[2][0] == 15 and r[2][1] == 18);

r = merge([[1, 4], [4, 5]]);
assert(r.length == 1);
assert(r[0][0] == 1 and r[0][1] == 5);

r = merge([[1, 4], [2, 3]]);
assert(r.length == 1);
assert(r[0][0] == 1 and r[0][1] == 4);

r = merge([[1, 4], [0, 2], [3, 5]]);
assert(r.length == 1);
assert(r[0][0] == 0 and r[0][1] == 5);

r = merge([]);
assert(r.length == 0);

r = merge([[1, 4]]);
assert(r.length == 1);
assert(r[0][0] == 1 and r[0][1] == 4);

print("PASS: 06-merge-intervals");
