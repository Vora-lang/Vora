// Problem #15: Majority Element (Easy)
// Element appears more than n/2 times. Boyer-Moore voting algorithm.
// Counter + candidate. O(n) time, O(1) space.

func majorityElement(nums) {
    let candidate = nums[0];
    let count = 1;
    for i in range(1, nums.length) {
        if (count == 0) {
            candidate = nums[i];
            count = 1;
        } else if (nums[i] == candidate) {
            count = count + 1;
        } else {
            count = count - 1;
        }
    }
    return candidate;
}

// Test cases
assert(majorityElement([3, 2, 3]) == 3);
assert(majorityElement([2, 2, 1, 1, 1, 2, 2]) == 2);
assert(majorityElement([1]) == 1);
assert(majorityElement([5, 5, 5, 1, 2, 5, 5]) == 5);
assert(majorityElement([-1, -1, -1, 2, -1]) == -1);
assert(majorityElement([0, 0, 0, 0, 1, 2, 0, 0]) == 0);

print("PASS: 15-majority-element");
