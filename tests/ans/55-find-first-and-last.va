// #34 Find First and Last Position of Element in Sorted Array (Medium)
// Find first and last position of target. Two binary searches (leftmost and rightmost).

func searchRange(nums, target) {
    if (nums.length == 0) {
        return [-1, -1];
    }

    // Find leftmost
    let left = 0;
    let right = nums.length - 1;
    let first = -1;

    while (left <= right) {
        let mid = left + int((right - left) / 2);
        if (nums[mid] == target) {
            first = mid;
            right = mid - 1;
        } else {
            if (nums[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
    }

    if (first == -1) {
        return [-1, -1];
    }

    // Find rightmost
    left = first;
    right = nums.length - 1;
    let last = first;

    while (left <= right) {
        let mid = left + int((right - left) / 2);
        if (nums[mid] == target) {
            last = mid;
            left = mid + 1;
        } else {
            if (nums[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
    }

    return [first, last];
}

func arraysEqual(a, b) {
    if (a.length != b.length) { return false; }
    let i = 0;
    while (i < a.length) {
        if (a[i] != b[i]) { return false; }
        i = i + 1;
    }
    return true;
}

// Tests
assert(arraysEqual(searchRange([5,7,7,8,8,10], 8), [3,4]), "Test 1 failed");
assert(arraysEqual(searchRange([5,7,7,8,8,10], 6), [-1,-1]), "Test 2 failed");
assert(arraysEqual(searchRange([], 0), [-1,-1]), "Test 3 failed");
assert(arraysEqual(searchRange([1], 1), [0,0]), "Test 4 failed");
assert(arraysEqual(searchRange([1], 0), [-1,-1]), "Test 5 failed");
assert(arraysEqual(searchRange([2,2], 2), [0,1]), "Test 6 failed");

print("55-find-first-and-last: PASS");
