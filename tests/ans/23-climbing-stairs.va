// Problem #23: Climbing Stairs (Easy)
// n stairs, can climb 1 or 2 steps at a time.
// DP: f(n) = f(n-1) + f(n-2). Fibonacci pattern.

func climbStairs(n) {
    if (n <= 2) {
        return n;
    }
    let prev2 = 1;  // f(1)
    let prev1 = 2;  // f(2)
    let cur = 0;
    for i in range(3, n + 1) {
        cur = prev1 + prev2;
        prev2 = prev1;
        prev1 = cur;
    }
    return cur;
}

// Recursive solution (slower but demonstrates the recurrence)
func climbStairsRec(n) {
    if (n <= 2) {
        return n;
    }
    return climbStairsRec(n - 1) + climbStairsRec(n - 2);
}

// Test cases — iterative
assert(climbStairs(2) == 2);
assert(climbStairs(3) == 3);
assert(climbStairs(4) == 5);
assert(climbStairs(5) == 8);
assert(climbStairs(1) == 1);
assert(climbStairs(6) == 13);
assert(climbStairs(10) == 89);
assert(climbStairs(15) == 987);

// Test recursive — only small n to avoid stack overflow
assert(climbStairsRec(2) == 2);
assert(climbStairsRec(3) == 3);
assert(climbStairsRec(5) == 8);
assert(climbStairsRec(10) == 89);

print("PASS: 23-climbing-stairs");
