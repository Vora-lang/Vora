// Problem #14: Single Number (Easy)
// Every element appears twice except one. Find that single one.
// No XOR operator in Vora. Use nested loop counting approach.

func singleNumber(nums) {
    for i in range(nums.length) {
        let count = 0;
        for j in range(nums.length) {
            if (nums[i] == nums[j]) {
                count = count + 1;
            }
        }
        if (count == 1) {
            return nums[i];
        }
    }
    return -1;
}

// Test cases
assert(singleNumber([2, 2, 1]) == 1);
assert(singleNumber([4, 1, 2, 1, 2]) == 4);
assert(singleNumber([1]) == 1);
assert(singleNumber([-1, -1, -2]) == -2);
assert(singleNumber([0, 1, 0]) == 1);

print("PASS: 14-single-number");
