// Problem #10: Set Matrix Zeroes (Medium)
// If element is 0, set entire row and column to 0.
// Use first row/col as flags.

func setZeroes(matrix) {
    let rows = matrix.length;
    if (rows == 0) {
        return matrix;
    }
    let cols = matrix[0].length;
    if (cols == 0) {
        return matrix;
    }

    let firstRowZero = false;
    let firstColZero = false;

    // Check if first row has any zero
    for j in range(cols) {
        if (matrix[0][j] == 0) {
            firstRowZero = true;
        }
    }

    // Check if first col has any zero
    for i in range(rows) {
        if (matrix[i][0] == 0) {
            firstColZero = true;
        }
    }

    // Use first row and col to mark zero rows/cols
    for i in range(1, rows) {
        for j in range(1, cols) {
            if (matrix[i][j] == 0) {
                matrix[i][0] = 0;
                matrix[0][j] = 0;
            }
        }
    }

    // Zero out based on markers (except first row/col)
    for i in range(1, rows) {
        for j in range(1, cols) {
            if (matrix[i][0] == 0 or matrix[0][j] == 0) {
                matrix[i][j] = 0;
            }
        }
    }

    // Zero out first row if needed
    if (firstRowZero) {
        for j in range(cols) {
            matrix[0][j] = 0;
        }
    }

    // Zero out first col if needed
    if (firstColZero) {
        for i in range(rows) {
            matrix[i][0] = 0;
        }
    }

    return matrix;
}

// Helper to compare 2D arrays
func matricesEqual(a, b) {
    if (a.length != b.length) {
        return false;
    }
    for i in range(a.length) {
        if (a[i].length != b[i].length) {
            return false;
        }
        for j in range(a[i].length) {
            if (a[i][j] != b[i][j]) {
                return false;
            }
        }
    }
    return true;
}

// Test cases
let r = setZeroes([[1, 1, 1], [1, 0, 1], [1, 1, 1]]);
assert(matricesEqual(r, [[1, 0, 1], [0, 0, 0], [1, 0, 1]]));

r = setZeroes([[0, 1, 2, 0], [3, 4, 5, 2], [1, 3, 1, 5]]);
assert(matricesEqual(r, [[0, 0, 0, 0], [0, 4, 5, 0], [0, 3, 1, 0]]));

r = setZeroes([[1, 2], [3, 4]]);
assert(matricesEqual(r, [[1, 2], [3, 4]]));

r = setZeroes([[0]]);
assert(matricesEqual(r, [[0]]));

r = setZeroes([[1], [0]]);
assert(matricesEqual(r, [[0], [0]]));

r = setZeroes([]);
assert(r.length == 0);

print("PASS: 10-set-matrix-zeroes");
