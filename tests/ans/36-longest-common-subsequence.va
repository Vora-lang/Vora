// Problem #36: Longest Common Subsequence (Medium)
// Find the length of the longest common subsequence of two strings.
// DP: if chars match, dp[i][j] = 1 + dp[i-1][j-1]; else max(dp[i-1][j], dp[i][j-1]).

func max(a, b) {
    if (a > b) {
        return a;
    }
    return b;
}

func longestCommonSubsequence(text1, text2) {
    let m = text1.length;
    let n = text2.length;

    if (m == 0 or n == 0) {
        return 0;
    }

    // Use a 1D DP array for space optimization
    // We'll use two rows: prev and cur
    let prev = [];
    for j in range(n + 1) {
        prev.add(0);
    }

    for i in range(1, m + 1) {
        let cur = [];
        cur.add(0);  // cur[0] = 0
        for j in range(1, n + 1) {
            if (text1[i - 1] == text2[j - 1]) {
                cur.add(prev[j - 1] + 1);
            } else {
                cur.add(max(prev[j], cur[j - 1]));
            }
        }
        prev = cur;
    }

    return prev[n];
}

// Test cases
assert(longestCommonSubsequence("abcde", "ace") == 3);          // "ace"
assert(longestCommonSubsequence("abc", "abc") == 3);            // "abc"
assert(longestCommonSubsequence("abc", "def") == 0);
assert(longestCommonSubsequence("", "abc") == 0);
assert(longestCommonSubsequence("abc", "") == 0);
assert(longestCommonSubsequence("bsbininm", "jmjkbkjkv") == 1);  // "b"
assert(longestCommonSubsequence("oxcpqrsvwf", "shmtulqrypy") == 2); // "qr"
assert(longestCommonSubsequence("hofubmnylkra", "pqhgxgdofcvmr") == 5); // "hofmr"
assert(longestCommonSubsequence("ezupkr", "ubmrapg") == 2);     // "ur" or "up"
assert(longestCommonSubsequence("abcba", "abcbcba") == 5);      // "abcba"

print("PASS: 36-longest-common-subsequence");
