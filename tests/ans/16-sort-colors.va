// Problem #16: Sort Colors (Medium)
// Array of 0, 1, 2 sort in-place.
// Vora limitation: no arr[i]=val. Use counting + rebuild approach.
// Count occurrences then reconstruct.

func sortColors(nums) {
    let count0 = 0;
    let count1 = 0;
    let count2 = 0;
    for i in range(nums.length) {
        if (nums[i] == 0) {
            count0 = count0 + 1;
        } else if (nums[i] == 1) {
            count1 = count1 + 1;
        } else {
            count2 = count2 + 1;
        }
    }
    let result = [];
    for i in range(count0) {
        result.add(0);
    }
    for i in range(count1) {
        result.add(1);
    }
    for i in range(count2) {
        result.add(2);
    }
    return result;
}

// Helper to check array equality
func arraysEqual(a, b) {
    if (a.length != b.length) {
        return false;
    }
    for i in range(a.length) {
        if (a[i] != b[i]) {
            return false;
        }
    }
    return true;
}

// Test cases
assert(arraysEqual(sortColors([2, 0, 2, 1, 1, 0]), [0, 0, 1, 1, 2, 2]));
assert(arraysEqual(sortColors([2, 0, 1]), [0, 1, 2]));
assert(arraysEqual(sortColors([0, 0, 0]), [0, 0, 0]));
assert(arraysEqual(sortColors([2, 2, 2]), [2, 2, 2]));
assert(arraysEqual(sortColors([1, 1, 1]), [1, 1, 1]));
assert(arraysEqual(sortColors([0]), [0]));
assert(arraysEqual(sortColors([1, 0]), [0, 1]));
assert(arraysEqual(sortColors([2, 1, 0]), [0, 1, 2]));

print("PASS: 16-sort-colors");
