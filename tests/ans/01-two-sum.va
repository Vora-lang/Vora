// Problem #1: Two Sum (Easy)
// Given array nums and target, return indices of two numbers that sum to target.
// O(n^2) nested loops (no hash map in Vora).

func twoSum(nums, target) {
    for i in range(nums.length) {
        for j in range(i + 1, nums.length) {
            if (nums[i] + nums[j] == target) {
                return [i, j];
            }
        }
    }
    return [];
}

// Test cases
let result = twoSum([2, 7, 11, 15], 9);
assert(result[0] == 0 and result[1] == 1);

result = twoSum([3, 2, 4], 6);
assert(result[0] == 1 and result[1] == 2);

result = twoSum([3, 3], 6);
assert(result[0] == 0 and result[1] == 1);

result = twoSum([1, 5, 3, 9], 8);
assert(result[0] == 1 and result[1] == 2);

result = twoSum([0, 4, 3, 0], 0);
assert(result[0] == 0 and result[1] == 3);

print("PASS: 01-two-sum");
