// #74 Search a 2D Matrix (Medium)
// Matrix where each row sorted + first of row > last of prev row.
// Binary search treating as 1D array.

func searchMatrix(matrix, target) {
    if (matrix.length == 0) {
        return false;
    }
    let m = matrix.length;
    let n = matrix[0].length;
    if (n == 0) {
        return false;
    }

    let left = 0;
    let right = m * n - 1;

    while (left <= right) {
        let mid = left + int((right - left) / 2);
        let row = int(mid / n);
        let col = int(mid % n);
        let val = matrix[row][col];

        if (val == target) {
            return true;
        }
        if (val < target) {
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }

    return false;
}

// Tests
let m1 = [[1,3,5,7],[10,11,16,20],[23,30,34,60]];
assert(searchMatrix(m1, 3) == true, "Test 1 failed");
assert(searchMatrix(m1, 13) == false, "Test 2 failed");
assert(searchMatrix(m1, 1) == true, "Test 3 failed");
assert(searchMatrix(m1, 60) == true, "Test 4 failed");
assert(searchMatrix(m1, 0) == false, "Test 5 failed");
assert(searchMatrix([[1]], 1) == true, "Test 6 failed");
assert(searchMatrix([[]], 1) == false, "Test 7 failed");

print("54-search-2d-matrix: PASS");
