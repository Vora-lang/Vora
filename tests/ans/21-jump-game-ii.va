// Problem #21: Jump Game II (Medium)
// Minimum number of jumps to reach last index.
// Greedy BFS levels: track current jump range end and next furthest.

func jump(nums) {
    let n = nums.length;
    if (n <= 1) {
        return 0;
    }
    let jumps = 0;
    let curEnd = 0;
    let curFarthest = 0;
    for i in range(n - 1) {
        let reach = i + nums[i];
        if (reach > curFarthest) {
            curFarthest = reach;
        }
        if (i == curEnd) {
            jumps = jumps + 1;
            curEnd = curFarthest;
            if (curEnd >= n - 1) {
                return jumps;
            }
        }
    }
    return jumps;
}

// Test cases
assert(jump([2, 3, 1, 1, 4]) == 2);
assert(jump([2, 3, 0, 1, 4]) == 2);
assert(jump([0]) == 0);
assert(jump([1]) == 0);
assert(jump([1, 2]) == 1);
assert(jump([1, 2, 3]) == 2);
assert(jump([5, 9, 3, 2, 1, 0, 2, 3, 3, 1, 0, 0]) == 3);
assert(jump([1, 1, 1, 1]) == 3);

print("PASS: 21-jump-game-ii");
