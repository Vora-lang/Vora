// Problem #3: Container With Most Water (Medium)
// Array of heights, find max water area between two lines.
// Two-pointer from ends.

func maxArea(height) {
    let left = 0;
    let right = height.length - 1;
    let maxWater = 0;

    while (left < right) {
        let h = height[left];
        if (height[right] < h) {
            h = height[right];
        }
        let area = h * (right - left);
        if (area > maxWater) {
            maxWater = area;
        }

        if (height[left] < height[right]) {
            left = left + 1;
        } else {
            right = right - 1;
        }
    }
    return maxWater;
}

// Test cases
assert(maxArea([1, 8, 6, 2, 5, 4, 8, 3, 7]) == 49);
assert(maxArea([1, 1]) == 1);
assert(maxArea([4, 3, 2, 1, 4]) == 16);
assert(maxArea([1, 2, 1]) == 2);
assert(maxArea([2, 3, 10, 5, 7, 8, 9]) == 36);
assert(maxArea([1, 2, 4, 3]) == 4);

print("PASS: 03-container-most-water");
