// Problem #5: Maximum Subarray (Medium)
// Kadane's algorithm - find subarray with max sum.

func maxSubArray(nums) {
    if (nums.length == 0) {
        return 0;
    }
    let currentSum = nums[0];
    let maxSum = nums[0];

    for i in range(1, nums.length) {
        let x = nums[i];
        if (currentSum + x > x) {
            currentSum = currentSum + x;
        } else {
            currentSum = x;
        }
        if (currentSum > maxSum) {
            maxSum = currentSum;
        }
    }
    return maxSum;
}

// Test cases
assert(maxSubArray([-2, 1, -3, 4, -1, 2, 1, -5, 4]) == 6);
assert(maxSubArray([1]) == 1);
assert(maxSubArray([5, 4, -1, 7, 8]) == 23);
assert(maxSubArray([-1]) == -1);
assert(maxSubArray([-2, -1]) == -1);
assert(maxSubArray([-1, 0, -2]) == 0);
assert(maxSubArray([1, 2, 3, 4, 5]) == 15);
assert(maxSubArray([-5, -2, -3, -1]) == -1);
assert(maxSubArray([]) == 0);

print("PASS: 05-maximum-subarray");
