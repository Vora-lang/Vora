// #78 Subsets (Medium)
// All subsets of distinct array. Iterative building approach.

func subsets(nums) {
    let result = [[]];
    let i = 0;

    while (i < nums.length) {
        let size = result.length;
        let j = 0;
        while (j < size) {
            // Make a copy of existing subset and add current element
            let newSubset = [];
            let k = 0;
            while (k < result[j].length) {
                newSubset.add(result[j][k]);
                k = k + 1;
            }
            newSubset.add(nums[i]);
            result.add(newSubset);
            j = j + 1;
        }
        i = i + 1;
    }

    return result;
}

// Tests
let r1 = subsets([1,2,3]);
assert(r1.length == 8, "Test 1 failed: count=" + r1.length);

let r2 = subsets([0]);
assert(r2.length == 2, "Test 2 failed: count=" + r2.length);

let r3 = subsets([]);
assert(r3.length == 1, "Test 3 failed: count=" + r3.length);
assert(r3[0].length == 0, "Test 3a failed");

let r4 = subsets([1,2]);
assert(r4.length == 4, "Test 4 failed: count=" + r4.length);

print("62-subsets: PASS");
