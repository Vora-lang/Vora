// Problem #17: Next Permutation (Medium)
// Find next lexicographically greater permutation in-place.
// Vora: no arr[i]=val. Build new array instead.
// 1. Find pivot (rightmost arr[i] < arr[i+1])
// 2. Find successor (rightmost arr[j] > pivot)
// 3. Swap them
// 4. Reverse suffix from i+1 to end

func nextPermutation(nums) {
    let n = nums.length;
    if (n <= 1) {
        return nums;
    }

    // Copy original to a mutable list
    let arr = [];
    for i in range(n) {
        arr.add(nums[i]);
    }

    // Step 1: Find pivot — rightmost index where arr[i] < arr[i+1]
    let i = n - 2;
    while (i >= 0 and arr[i] >= arr[i + 1]) {
        i = i - 1;
    }

    if (i >= 0) {
        // Step 2: Find successor — rightmost arr[j] > arr[i]
        let j = n - 1;
        while (j >= 0 and arr[j] <= arr[i]) {
            j = j - 1;
        }
        // Step 3: Swap pivot and successor using array rebuild
        let result = [];
        for k in range(n) {
            if (k == i) {
                result.add(arr[j]);
            } else if (k == j) {
                result.add(arr[i]);
            } else {
                result.add(arr[k]);
            }
        }
        arr = result;
    }

    // Step 4: Reverse the suffix from i+1 to end
    let left = i + 1;
    let right = n - 1;
    while (left < right) {
        let result = [];
        for k in range(n) {
            if (k == left) {
                result.add(arr[right]);
            } else if (k == right) {
                result.add(arr[left]);
            } else {
                result.add(arr[k]);
            }
        }
        arr = result;
        left = left + 1;
        right = right - 1;
    }

    return arr;
}

// Helper to check array equality
func arraysEqual(a, b) {
    if (a.length != b.length) {
        return false;
    }
    for i in range(a.length) {
        if (a[i] != b[i]) {
            return false;
        }
    }
    return true;
}

// Test cases
assert(arraysEqual(nextPermutation([1, 2, 3]), [1, 3, 2]));
assert(arraysEqual(nextPermutation([3, 2, 1]), [1, 2, 3]));
assert(arraysEqual(nextPermutation([1, 1, 5]), [1, 5, 1]));
assert(arraysEqual(nextPermutation([1, 3, 2]), [2, 1, 3]));
assert(arraysEqual(nextPermutation([2, 3, 1]), [3, 1, 2]));
assert(arraysEqual(nextPermutation([1]), [1]));
assert(arraysEqual(nextPermutation([1, 2]), [2, 1]));
assert(arraysEqual(nextPermutation([1, 5, 8, 4, 7, 6, 5, 3, 1]), [1, 5, 8, 5, 1, 3, 4, 6, 7]));

print("PASS: 17-next-permutation");
