// ============================================================
// 题目 1：纯循环压力测试
// 原题：循环 10 亿次（1,000,000,000），每次 sum += 1
// Vora 实测：10 万次 ~1 秒 → 10 亿次约 2.8 小时
// 请修改 LOOPS 值到你想要的规模后运行
// ============================================================

let LOOPS = 10000000  // 1千万（原题 1,000,000,000）
print("=== 纯循环压力测试 ===")
print("循环次数: " + LOOPS)

let t0 = clock()
let sum = 0
let i = 0
while (i < LOOPS) {
    sum += 1
    i += 1
}
let elapsed = clock() - t0

print("sum = " + sum)
print("耗时: " + elapsed + " 秒")
