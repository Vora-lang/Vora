// ============================================================
// 题目 3：大数组读写测试（内存性能）
// 原题：1 亿个整数全赋值为 1，再全部求和
// Vora 限制：不支持 arr[i]=x 索引赋值，改用循环追加 arr+=1
//           每个 Value ~32+ 字节，1 亿项 ≈ 3.2GB+
//           修改 SIZE 调整规模，默认 100 万
// ============================================================

let SIZE = 1000000  // 100 万（原题 100,000,000）
print("=== 大数组读写测试 ===")
print("数组大小: " + SIZE)

// --- 创建数组，全部赋值为 1 ---
print("创建数组（全部赋值为 1）...")
let t0 = clock()

let arr = []
let i = 0
while (i < SIZE) {
    arr += 1       // Vora 数组追加（无索引赋值）
    i += 1
}
let t1 = clock()
print("  创建耗时: " + (t1 - t0) + " 秒")

// --- 全部求和 ---
print("求和...")
let sum = 0
i = 0
while (i < SIZE) {
    sum += arr[i]   // 索引读取可用
    i += 1
}
let t2 = clock()
print("  求和耗时: " + (t2 - t1) + " 秒")

print("-----------------------------------")
print("sum = " + sum)
print("avg = " + (sum / SIZE))
print("总耗时: " + (t2 - t0) + " 秒")
