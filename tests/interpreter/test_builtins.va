// interpreter/test_builtins.va — Built-in function tests
// Run: vora tests/interpreter/test_builtins.va

print("=== Built-in Tests ===")

// int()
assert(int(3.14) == 3, "int(float)")
assert(int("42") == 42, "int(string)")
assert(int(true) == 1, "int(true)")
assert(int(false) == 0, "int(false)")
assert(int(10) == 10, "int(int)")

// float()
assert(float(3) == 3.0, "float(int)")
assert(float("3.14") == 3.14, "float(string)")
assert(float(true) == 1.0, "float(true)")

// range()
let r1 = range(3)
assert(r1[0] == 0, "range(3)[0]")
assert(r1[1] == 1, "range(3)[1]")
assert(r1[2] == 2, "range(3)[2]")

let r2 = range(2, 5)
assert(r2[0] == 2, "range(2,5)[0]")
assert(r2[2] == 4, "range(2,5)[2]")

let r3 = range(5, 0, -1)
assert(r3[0] == 5, "range(5,0,-1)[0]")
assert(r3[4] == 1, "range(5,0,-1)[4]")

// clock() returns a number
let t = clock()
assert(t > 0, "clock returns positive")

// input with empty stdin returns ""
// let result = input("")
// assert(result == "", "input empty prompt")

print("Built-in tests: PASS")
