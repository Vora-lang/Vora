// test_list_comp.va — List comprehension tests
// Run: vora tests/interpreter/test_list_comp.va

print("=== List Comprehension Tests ===")

// --- Basic mapping ---
let r1 = [i for i in range(5)]
assert(r1.length == 5, "basic: length")
assert(r1[0] == 0, "basic: [0]")
assert(r1[4] == 4, "basic: [4]")

// --- Empty iterable ---
let r2 = [x for x in []]
assert(r2.length == 0, "empty iterable: length")

// --- With filter ---
let r3 = [i for i in range(30) if i % 3 == 0]
assert(r3.length == 10, "filter: correct count")
assert(r3[0] == 0, "filter: first")
assert(r3[9] == 27, "filter: last")

// --- Filter that removes everything ---
let r4 = [i for i in range(5) if false]
assert(r4.length == 0, "false filter: empty")

// --- String transformation with filter ---
let names = ["alice", "bob", "charlie"]
let r5 = [name.upper() for name in names if name.length > 3]
assert(r5.length == 2, "string transform: count")
assert(r5[0] == "ALICE", "string transform: alice")
assert(r5[1] == "CHARLIE", "string transform: charlie")

// --- Nested comprehension ---
// [[x*y for x in range(1,4)] for y in range(1,4)]
// y=1 → [1,2,3], y=2 → [2,4,6], y=3 → [3,6,9]
let r6 = [[x * y for x in range(1, 4)] for y in range(1, 4)]
assert(r6.length == 3, "nested: outer length")
assert(r6[0].length == 3, "nested: inner length")
assert(r6[0][0] == 1, "nested: [0][0]")
assert(r6[0][2] == 3, "nested: [0][2]")
assert(r6[1][0] == 2, "nested: [1][0]")
assert(r6[1][2] == 6, "nested: [1][2]")
assert(r6[2][0] == 3, "nested: [2][0]")
assert(r6[2][2] == 9, "nested: [2][2]")

// --- Single element iterable ---
let r7 = [i * 10 for i in [5]]
assert(r7.length == 1, "single: length")
assert(r7[0] == 50, "single: value")

// --- Comprehension bound to variable (value not discarded) ---
let _discard = [i for i in range(3)]
assert(_discard.length == 3, "expression statement: length")

// --- Squares ---
let squares = [i * i for i in range(1, 6)]
assert(squares.length == 5, "squares: length")
assert(squares[0] == 1, "squares: 1^2")
assert(squares[4] == 25, "squares: 5^2")

// --- Computed iterable ---
let evens = [x for x in range(0, 10) if x % 2 == 0]
assert(evens.length == 5, "evens: length")
assert(evens[0] == 0, "evens: 0")
assert(evens[4] == 8, "evens: 8")

// --- Comprehension using function call result expression ---
func double(x) { return x * 2 }
let doubled = [double(i) for i in range(4)]
assert(doubled.length == 4, "func: length")
assert(doubled[0] == 0, "func: double(0)")
assert(doubled[3] == 6, "func: double(3)")

// --- Variable binding preservation ---
let factor = 10
let scaled = [x * factor for x in range(1, 4)]
assert(scaled.length == 3, "capture: length")
assert(scaled[0] == 10, "capture: 1*10")
assert(scaled[2] == 30, "capture: 3*10")

// --- Triple-nested comprehension (Bug #3: temp local through 3 levels) ---
let triple = [[[x * y * z for x in range(1, 3)] for y in range(1, 3)] for z in range(1, 3)]
assert(triple.length == 2, "triple: outer length")
assert(triple[0].length == 2, "triple: mid length")
assert(triple[0][0].length == 2, "triple: inner length")
assert(triple[0][0][0] == 1, "triple: 1*1*1")
assert(triple[0][0][1] == 2, "triple: 2*1*1")
assert(triple[1][1][1] == 8, "triple: 2*2*2")

// --- Deeply nested function calls (non-list-comp nesting) ---
func inc(x) { return x + 1 }
let deep = [inc(inc(inc(x))) for x in range(3)]
assert(deep[0] == 3, "deep: 0+3")
assert(deep[2] == 5, "deep: 2+3")

// --- If true (always take, Bug #2: both condition paths exercised) ---
let allTrue = [i for i in range(5) if true]
assert(allTrue.length == 5, "if true: all taken")

// --- Alternating condition (tests true/false interleaving, Bug #2) ---
let alt = [i for i in range(6) if i % 2 == 0]
assert(alt.length == 3, "alternating: count")
assert(alt[0] == 0, "alternating: 0")
assert(alt[2] == 4, "alternating: 4")

// --- Comprehension inside for-in (tests scope interaction) ---
let mixed = []
for y in range(1, 4) {
    let inner = [x * y for x in range(1, 4)]
    mixed = mixed + [inner]
}
assert(mixed.length == 3, "mixed: outer length")
assert(mixed[0][0] == 1, "mixed: y=1 first")
assert(mixed[2][2] == 9, "mixed: y=3 last")

// --- Top-level expression statement (Bug #1: scopeDepth == 0 path) ---
// Note: semicolons needed before [ to prevent parser from treating
// it as an index expression on previous statement.
let _topLevel = [i for i in [42]]
assert(_topLevel.length == 1, "top-level: length")
assert(_topLevel[0] == 42, "top-level: value")

// --- Empty comprehension with condition always false ---
let emptyFilter = [i for i in range(10) if false]
assert(emptyFilter.length == 0, "empty filter: length")

// --- Large comprehension (many iterations, exercises loop repeatedly) ---
let big = [i for i in range(100) if i % 25 == 0]
assert(big.length == 4, "big: count")
assert(big[0] == 0, "big: first")
assert(big[3] == 75, "big: last")

print("=== All list comprehension tests passed ===")
