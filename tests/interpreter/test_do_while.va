// test_do_while.va — Do-while loop tests
// Run: vora tests/interpreter/test_do_while.va

print("=== Interpreter: Do-While Tests ===")

// --- Basic do-while (executes exactly N times) ---
let dw1 = 0
do {
    dw1 = dw1 + 1
} while (dw1 < 5)
assert(dw1 == 5, "basic do-while")

// --- Do-while with always-false condition (executes exactly once) ---
let dw2 = 0
do {
    dw2 = 42
} while (false)
assert(dw2 == 42, "do-while executes once with false condition")

// --- Do-while with break ---
let dw3 = 0
do {
    dw3 = dw3 + 1
    if (dw3 >= 3) { break }
} while (true)
assert(dw3 == 3, "break in do-while")

// --- Do-while with continue ---
let dw4 = 0
let dw4Sum = 0
do {
    dw4 = dw4 + 1
    if (dw4 > 5) { break }
    if (dw4 % 2 == 0) { continue }
    dw4Sum = dw4Sum + dw4
} while (dw4 < 10)
assert(dw4Sum == 9, "continue in do-while")  // 1+3+5

// --- Nested: do-while inside while ---
let dwn = 0
let outer = 0
while (outer < 2) {
    outer = outer + 1
    do {
        dwn = dwn + 1
    } while (false)
}
assert(dwn == 2, "nested do-while in while")

// --- Nested: while inside do-while ---
let dwx = 0
do {
    let inner = 0
    while (inner < 3) {
        inner = inner + 1
        dwx = dwx + 1
    }
} while (false)
assert(dwx == 3, "while in do-while")

// --- Single-statement body ---
let dw5 = 0
do
    dw5 = dw5 + 1
while (dw5 < 3)
assert(dw5 == 3, "single-statement do-while")

// --- Break in nested do-while ---
let dwn2 = 0
do {
    let inner = 0
    do {
        inner = inner + 1
        dwn2 = dwn2 + 1
        if (inner >= 2) { break }
    } while (true)
} while (dwn2 < 2)
assert(dwn2 == 2, "break in nested do-while")

print("test_do_while OK")
