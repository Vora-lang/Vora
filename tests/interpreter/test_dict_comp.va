// test_dict_comp.va — Dict comprehension tests
// Run: vora tests/interpreter/test_dict_comp.va

print("=== Dict Comprehension Tests ===")

// --- Basic mapping: string -> length ---
let d1 = {k: k.length for k in ["a", "bb", "ccc"]}
assert(d1.length == 3, "basic: length")
assert(d1["a"] == 1, "basic: 'a'->1")
assert(d1["ccc"] == 3, "basic: 'ccc'->3")

// --- Empty iterable ---
let d2 = {k: 0 for k in []}
assert(d2.length == 0, "empty iterable: length")

// --- With filter ---
let listdemo = ["Google", "Runoob", "Taobao"]
let d3 = {key: key.length for key in listdemo if key.length == 6}
assert(d3.length == 3, "filter: count")
assert(d3["Google"] == 6, "filter: Google")
assert(d3["Runoob"] == 6, "filter: Runoob")

// --- Filter that removes everything ---
let d4 = {k: k for k in ["a", "b"] if false}
assert(d4.length == 0, "false filter: empty")

// --- Value transformation ---
let d5 = {k: k * 2 for k in [1, 2, 3]}
assert(d5.length == 3, "transform: length")
assert(d5["1"] == 2, "transform: 1->2")
assert(d5["3"] == 6, "transform: 3->6")

// --- Duplicate keys (last wins via dict merge) ---
let d6 = {k: 1 for k in ["a", "a", "a"]}
assert(d6.length == 1, "duplicate: length")
assert(d6["a"] == 1, "duplicate: value")

// --- Nested list comprehension as value (Bug #3 regression test) ---
let d7 = {k: [i for i in range(3)] for k in ["x", "y"]}
assert(d7.length == 2, "nested list: length")
assert(d7["x"].length == 3, "nested list: inner length")
assert(d7["x"][0] == 0, "nested list: [0]")
assert(d7["y"][2] == 2, "nested list: [2]")

// --- If true (always take, Bug #2 regression) ---
let d8 = {k: k for k in ["a", "b"] if true}
assert(d8.length == 2, "if true: length")

// --- Alternating condition ---
let d9 = {k: k for k in ["a", "bb", "ccc"] if k.length > 1}
assert(d9.length == 2, "alternating: count")
assert(d9["bb"] == "bb", "alternating: bb")

// --- Triple-nested (dict → list → list) ---
let d10 = {k: [[i * j for i in range(1, 3)] for j in range(1, 3)] for k in ["t"]}
assert(d10.length == 1, "triple: length")
assert(d10["t"].length == 2, "triple: mid length")
assert(d10["t"][0][1] == 2, "triple: value")

print("=== All dict comprehension tests passed ===")
