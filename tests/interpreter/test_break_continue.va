// interpreter/test_break_continue.va — Break/continue in all loop types
// Run: vora tests/interpreter/test_break_continue.va

print("=== Interpreter: Break/Continue Tests ===")

// --- Break in while ---
let bw = 0
while (true) {
    bw = bw + 1
    if (bw >= 5) { break }
}
assert(bw == 5, "break in while")

// --- Continue in while ---
let cw = 0
let cwSum = 0
while (cw < 8) {
    cw = cw + 1
    if (cw % 2 == 0) { continue }
    cwSum = cwSum + cw
}
assert(cwSum == 16, "continue in while")  // 1+3+5+7

// --- Break in for-in ---
let found = false
for item in [10, 20, 30, 40, 50] {
    if (item == 30) {
        found = true
        break
    }
}
assert(found == true, "break in for-in")

// --- Continue in for-in ---
let fiSum = 0
for item in [1, 2, 3, 4, 5] {
    if (item == 3) { continue }
    fiSum = fiSum + item
}
assert(fiSum == 12, "continue in for-in")  // 1+2+4+5

// --- Break in C-for ---
let bcf = 0
for (let i = 0; i < 100; i = i + 1) {
    bcf = i
    if (i >= 7) { break }
}
assert(bcf == 7, "break in C-for")

// --- Continue in C-for ---
let ccf = 0
for (let i = 0; i < 8; i = i + 1) {
    if (i % 2 == 0) { continue }
    ccf = ccf + i
}
assert(ccf == 16, "continue in C-for")  // 1+3+5+7

// --- Break in nested while ---
let bnw = 0
let outerCount = 0
while (outerCount < 5) {
    outerCount = outerCount + 1
    let innerCount = 0
    while (innerCount < 10) {
        innerCount = innerCount + 1
        if (innerCount == 3) { break }
        bnw = bnw + 1
    }
}
assert(bnw == 10, "break nested while")  // 5 * 2

// --- Break in while-in-for ---
let bif = 0
for item in [1, 2, 3] {
    let w = 0
    while (w < 10) {
        w = w + 1
        if (w == 3) { break }
        bif = bif + 1
    }
}
assert(bif == 6, "break while in for")  // 3 * 2

// --- Continue in C-for nested ---
let cfn = 0
for (let a = 0; a < 3; a = a + 1) {
    for (let b = 0; b < 4; b = b + 1) {
        if (b == 2) { continue }
        cfn = cfn + 1
    }
}
assert(cfn == 9, "continue nested C-for")  // 3 * 3

print("Break/continue tests: PASS")
