// parser/test_expressions_ext.va — Extended expression parsing tests (TEST-012)
// Run: vora tests/parser/test_expressions_ext.va

print("=== Parser: Extended Expression Tests ===")

// --- Null coalescing (??) ---
assert((null ?? 42) == 42, "null coalescing null")
assert((10 ?? 42) == 10, "null coalescing non-null")
assert((0 ?? 100) == 0, "null coalescing zero (not null)")

// --- Optional chaining (?.) ---
let obj = {"name": "Vora"}
assert(obj?.["name"] == "Vora", "optional chain valid")
let n = null
assert(n?.["anything"] == null, "optional chain null short-circuit")

// --- List comprehension ---
let squares = [i * i for i in range(1, 4)]
assert(squares[0] == 1, "list comp [0]")
assert(squares[2] == 9, "list comp [2]")

// List comprehension with filter
let evens = [i for i in range(10) if i % 2 == 0]
assert(evens.length == 5, "list comp filter length")
assert(evens[0] == 0, "list comp filter [0]")
assert(evens[4] == 8, "list comp filter [4]")

// --- Spread in function calls ---
func sum3(a, b, c) {
    return a + b + c
}
let args = [1, 2, 3]
assert(sum3(...args) == 6, "call spread")

// --- Dict comprehension ---
let words = ["a", "bb", "ccc"]
let lens = {w: w.length for w in words}
assert(lens["bb"] == 2, "dict comp value")

print("Parser extended expression tests: PASS")
